From 3e15ce2ca5b80ad25349f61d1a58a4924e9fcac9 Mon Sep 17 00:00:00 2001
From: Francesco Valla <francesco@valla.it>
Date: Sun, 3 May 2026 15:19:36 +0200
Subject: [PATCH] core: imx: disable external DTB overlay for i.MX93

For Falcon boot on i.MX93 is required that the OP-TEE itself modifies
the Linux kernel devicetree, passed as x3, and not an external overlay.

Signed-off-by: Francesco Valla <francesco@valla.it>
---
 core/arch/arm/plat-imx/conf.mk | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/core/arch/arm/plat-imx/conf.mk b/core/arch/arm/plat-imx/conf.mk
index db223d3929bc..abd97b476f61 100644
--- a/core/arch/arm/plat-imx/conf.mk
+++ b/core/arch/arm/plat-imx/conf.mk
@@ -267,6 +267,7 @@ CFG_IMX_ELE ?= y
 CFG_IMX_TRUSTED_ARM_CE = y
 CFG_IN_TREE_EARLY_TAS += trusted_keys/f04a0fe7-1f5d-4b9b-abf7-619b85b4ce8c
 CFG_IMX_ELE_TEST_PTA ?= n
+CFG_EXTERNAL_DTB_OVERLAY = n
 else ifneq (,$(filter $(PLATFORM_FLAVOR),$(mx95-flavorlist)))
 $(call force,CFG_MX95,y)
 $(call force,CFG_ARM64_core,y)
@@ -627,7 +628,7 @@ $(call force,CFG_SECURE_TIME_SOURCE_CNTPCT,y)
 
 CFG_CRYPTO_WITH_CE ?= y
 CFG_DT ?= y
-CFG_EXTERNAL_DTB_OVERLAY = y
+CFG_EXTERNAL_DTB_OVERLAY ?= y
 
 supported-ta-targets = ta_arm64
 endif
-- 
2.54.0

