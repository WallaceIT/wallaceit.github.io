-	ret = uclass_get_device_by_seq(UCLASS_I2C, TCPC1_I2C_BUS, &bus);
+	ret = uclass_get_device_by_name(UCLASS_I2C, TCPC1_I2C_BUS, &bus);
 	if (ret) {
-		printf("Failed to get I2C bus %d\n", TCPC1_I2C_BUS);
+		printf("Failed to get I2C bus %s\n", TCPC1_I2C_BUS);
 		return ret;
 	}
 
