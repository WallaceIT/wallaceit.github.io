 #include <dm/uclass.h>
@@ -38,10 +42,120 @@ static struct _drams {
 	{0x18, &dram_timing_2GB, "2GB DRAM" },
 };
 
+#if CONFIG_IS_ENABLED(OS_BOOT)
+int spl_start_uboot(void)
+{
+	int start_uboot = 0;
+
+	if (!serial_tstc())
+		return 0;
+
+	/* break into full u-boot on 'c' */
+	return serial_tstc() && serial_getc() == 'c';
+}
+
+int spl_board_boot_device(enum boot_device boot_dev_spl)
+{
+	switch (boot_dev_spl) {
+	case SD1_BOOT:
+	case MMC1_BOOT:
+		return BOOT_DEVICE_MMC1;
+	case SD2_BOOT:
+	case MMC2_BOOT:
+		return BOOT_DEVICE_MMC2;
+	default:
+		return BOOT_DEVICE_BOOTROM;
+	}
+}
+
+void board_boot_order(u32 *spl_boot_list)
+{
+	spl_boot_list[0] = spl_boot_device();
+	spl_boot_list[1] = BOOT_DEVICE_BOOTROM;
+}
+
+#if IS_ENABLED(CONFIG_OF_BOARD_SETUP) && CONFIG_IS_ENABLED(OF_LIBFDT)
+static char bootargs[256] = "console=ttyLP0,115200";
+
+const char *board_fdt_chosen_bootargs(const struct fdt_property *fdt_ba)
+{
+	const char *rootarg;
+
+	switch (spl_boot_device()) {
+	case BOOT_DEVICE_MMC1:
+		rootarg = " root=/dev/mmcblk0p2 rootwait";
+		break;
+	case BOOT_DEVICE_MMC2:
+	case BOOT_DEVICE_MMC2_2:
+	default:
+		rootarg = " root=/dev/mmcblk1p2 rootwait";
+		break;
+	}
+
+	return strncat(bootargs, rootarg, sizeof(bootargs) - strlen(bootargs) - 1);
+}
+
+int ft_board_setup(void *blob, struct bd_info *bd)
+{
+	return fdt_chosen(blob);
+}
+#endif
+
+static void spl_enable_caches(void)
+{
+#if !(defined(CONFIG_SYS_ICACHE_OFF) && defined(CONFIG_SYS_DCACHE_OFF))
+	gd->ram_top = CFG_SYS_SDRAM_BASE;
+
+	dram_init();
+	dram_init_banksize();
+
+	/* reserve TLB table */
+	gd->arch.tlb_size = PGTABLE_SIZE;
+
+	gd->ram_top += get_effective_memsize();
+	gd->relocaddr = gd->ram_top;
+
+	gd->arch.tlb_addr = gd->relocaddr - gd->arch.tlb_size;
+	gd->arch.tlb_addr &= ~(0x10000 - 1);
+	debug("TLB table from %08lx to %08lx\n", gd->arch.tlb_addr,
+	      gd->arch.tlb_addr + gd->arch.tlb_size);
+	gd->relocaddr = gd->arch.tlb_addr;
+
+	enable_caches();
+#endif
+}
+
+void spl_board_prepare_for_boot(void)
+{
+	/* Ensure caches are always disabled after SPL */
+	if (IS_ENABLED(CONFIG_CMO_BY_VA_ONLY)) {
+		/*
+		 * Disable D-cache.
+		 */
+		dcache_disable();
+	} else {
+		/*
+		 * Turn off I-cache and invalidate it
+		 */
+		icache_disable();
+		invalidate_icache_all();
+
+		/*
+		 * turn off D-cache
+		 * dcache_disable() in turn flushes the d-cache and disables
+		 * MMU
+		 */
+		dcache_disable();
+		invalidate_dcache_all();
+	}
+}
+
+#else // !CONFIG_SPL_OS_BOOT
 int spl_board_boot_device(enum boot_device boot_dev_spl)
 {
 	return BOOT_DEVICE_BOOTROM;
 }
+#endif
 
 void spl_board_init(void)
 {
@@ -51,6 +165,12 @@ void spl_board_init(void)
 	if (ret)
 		printf("Fail to start RNG: %d\n", ret);
 
+#if CONFIG_IS_ENABLED(OS_BOOT)
+	spl_enable_caches();
+
+	board_late_init();
+#endif
+
 	puts("Normal Boot\n");
 }
 
@@ -156,6 +276,8 @@ void board_init_f(ulong dummy)
 
 	arch_cpu_init();
 
+	board_early_init_f();
+
 	spl_early_init();
 
 	preloader_console_init();
